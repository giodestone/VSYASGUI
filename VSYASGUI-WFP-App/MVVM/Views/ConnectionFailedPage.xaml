<Page x:Class="VSYASGUI_WFP_App.MVVM.Views.ConnectionFailedPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:svg="http://sharpvectors.codeplex.com/runtime/"
      xmlns:svgc="http://sharpvectors.codeplex.com/svgc/"
      xmlns:local="clr-namespace:VSYASGUI_WFP_App.MVVM.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ConnectionFailedPage" DataContext="{Binding Mode=OneWay, RelativeSource={RelativeSource Self}}"
      Loaded="Page_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="2*"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="1" Grid.Column="1" Background="AliceBlue" BorderThickness="1,1,1,1" CornerRadius="6,6,6,6" BorderBrush="#FF616161">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>
                <StackPanel Margin="6 6 6 6" Grid.Row="0">
                    <Label Content="Unable to connect" FontWeight="Bold"/>
                    <Separator/>
                    <TextBlock Margin="6,6,0,0" x:Name="FailureReasonLabel" Text="{Binding FailureReason}" TextWrapping="Wrap" />
                    <TextBlock Margin="6 0 0 0" x:Name="ResolutionSuggestionsLabel" Text="{Binding ResolutionSuggestions}" TextWrapping="Wrap"/>
                </StackPanel>
                <Button Grid.Row="1" Content="Return to Connection Screen" Width="160" Click="ReturnButton_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Page>
