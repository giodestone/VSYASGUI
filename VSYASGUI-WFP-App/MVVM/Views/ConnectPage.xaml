<Page x:Class="VSYASGUI_WFP_App.Pages.ConnectPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:VSYASGUI_WFP_App.Pages"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Connect Page"
      
      mc:Ignorable="d" 
      xmlns:viewModels="clr-namespace:VSYASGUI_WFP_App.MVVM.ViewModels"
      x:ClassModifier="internal"
      d:DataContext="{d:DesignInstance viewModels:ConfigPresenter}"
      Loaded="Page_Loaded">

    <Page.DataContext>
        <viewModels:ConfigPresenter/>
    </Page.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition Height="200"/>
            <RowDefinition />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="400"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border Grid.Row="1"  Grid.Column="1" Background="AliceBlue"  BorderThickness="1,1,1,1" CornerRadius="6,6,6,6" BorderBrush="#FF616161">
            <StackPanel Margin="6 6 6 6">
                <Label Content="VS YAS GUI" FontWeight="Bold"/>
                <Label Margin="0 0 0 1" Content="Vintage Story Yet Another Simple Graphical User Interface"/>

                <StackPanel>
                    <Label Grid.Column="0" Content="Server API Key"></Label>
                    <ComboBox x:Name="APIKeyComboBox" Grid.Column="1" Margin="0,0,0,5" 
                          IsEditable="True" 
                          IsReadOnly="False" 
                          IsTextSearchEnabled="True"
                          SelectedIndex="0"
                          ItemsSource="{Binding ApiKeyHistory}" 
                          Text="{Binding CurrentlySelectedApiKey, UpdateSourceTrigger=LostFocus}" />

                    <Label Grid.Column="0" Grid.Row="1" Content="Server HTTP Endpoint Address"/>
                    <ComboBox x:Name="EndpointComboBox" Grid.Column="1" Grid.Row="1" Margin="0,0,0,5"
                          IsEditable="True" 
                          IsReadOnly="False" 
                          IsTextSearchEnabled="True"
                          SelectedIndex="0"
                          ItemsSource="{Binding EndpointHistory}" 
                          Text="{Binding CurrentlySelectedEndpoint, UpdateSourceTrigger=LostFocus}" />
                </StackPanel>

                <Button x:Name="ConnectButton" Content="Connect" Width="100" Command="{Binding AddCurrentlySelectedToCollection}" Click="ConnectButton_Click"/>

            </StackPanel>
        </Border>


    </Grid>
</Page>
